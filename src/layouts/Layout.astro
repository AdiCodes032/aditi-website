---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A cute little surprise just for you!" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    
    <!-- Open Graph tags for cute preview if shared -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col justify-between selection:bg-pink-soft selection:text-pink-primary">
    <slot />
  </body>
</html>
